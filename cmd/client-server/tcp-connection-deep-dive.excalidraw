    {
      "id": "uMAJFe5N71eRivJe26Z3-",
      "type": "image",
      "x": -2842.10146582378,
      "y": 2817.390138723473,
      "width": 132.6559386005853,
      "height": 49.251662840867716,
      "angle": 0,
      "strokeColor": "transparent",
