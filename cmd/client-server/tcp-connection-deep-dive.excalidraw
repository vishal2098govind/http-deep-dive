      "link": null,
      "locked": false,
      "text": "// non-blocking (delay=0) fd not returned until:\nin case of conn.CloseWrite(), until FIN from\nserver is not received",
      "fontSize": 19.8268446981325,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// non-blocking (delay=0) fd not returned until:\nin case of conn.CloseWrite(), until FIN from server is not received",
      "autoResize": false,
      "lineHeight": 1.25
    },
