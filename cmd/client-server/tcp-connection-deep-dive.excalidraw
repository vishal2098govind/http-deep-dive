      "link": null,
      "locked": false,
      "text": "NOW kernel frees:\n        tcp_sock structure from memory\n        rcv_buff\n        send_buff\n        all TCP state (seq numbers, timers, etc.)",
      "fontSize": 15.998848707443635,
      "fontFamily": 5,
