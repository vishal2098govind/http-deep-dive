      ],
      "updated": 1777746209105,
      "link": null,
      "locked": false,
      "text": "func main() {\n\n        l, err := net.Listen(\"tcp\", \":8080\")\n        if err != nil {\n                fmt.Println(\"failed to listen tcp on port :6379\", err)\n                return\n        }\n\n        for {\n\n                conn, err := l.Accept()\n                if err != nil {\n                        fmt.Println(\"failed to accept new connection\", err)\n                        return\n                }\n\n                go handleConn(conn)\n        }\n\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "func main() {\n\n        l, err := net.Listen(\"tcp\", \":8080\")\n        if err != nil {\n                fmt.Println(\"failed to listen tcp on port :6379\", err)\n                return\n        }\n\n        for {\n\n                conn, err := l.Accept()\n                if err != nil {\n                        fmt.Println(\"failed to accept new connection\", err)\n                        return\n                }\n\n                go handleConn(conn)\n        }\n\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
