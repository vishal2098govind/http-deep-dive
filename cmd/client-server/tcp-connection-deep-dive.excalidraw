    {
      "id": "5Z4INBt9bdUfNAUHutnWq",
      "type": "text",
      "x": 17522.383465520244,
      "y": -653.7677219651978,
      "width": 403.8004455566406,
      "height": 262.1951256683622,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bH2",
      "roundness": null,
      "seed": 407766118,
      "version": 750,
      "versionNonce": 551080954,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375443,
      "link": null,
      "locked": false,
      "text": "// pseudocode of what netpoll() does with results\nfor each ready fd in epoll results {\n    pd = pollDescForFd(fd)\n    if event is EPOLLIN {\n        g = pd.rg        // find the parked goroutine\n        pd.rg = nil\n        runqueue.add(g)  // put it back on the run queue\n    }\n    if event is EPOLLOUT {\n        g = pd.wg\n        pd.wg = nil\n        runqueue.add(g)\n    }\n}",
      "fontSize": 14.982578609620697,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// pseudocode of what netpoll() does with results\nfor each ready fd in epoll results {\n    pd = pollDescForFd(fd)\n    if event is EPOLLIN {\n        g = pd.rg        // find the parked goroutine\n        pd.rg = nil\n        runqueue.add(g)  // put it back on the run queue\n    }\n    if event is EPOLLOUT {\n        g = pd.wg\n        pd.wg = nil\n        runqueue.add(g)\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
