      "id": "3Dls63CxtEYamaVwvPcnz",
      "type": "text",
      "x": 4110.094719666044,
      "y": 171.95342396476553,
      "width": 871.8003196074955,
      "height": 227.00678337912547,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCf",
      "roundness": null,
      "seed": 909923238,
      "version": 442,
      "versionNonce": 180520506,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "The goroutine is unparked\nonly when something arrives\nin the accept queue.",
      "fontSize": 60.53514223443345,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The goroutine is unparked only when something arrives in the accept queue.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "l7Vo6a150TeeTc8hPWQbM",
      "type": "text",
      "x": 6094.4798659340595,
      "y": -486.67148854395055,
      "width": 281.11981201171875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCg",
      "roundness": null,
      "seed": 2147413734,
      "version": 85,
      "versionNonce": 1405726458,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "What actually happens in Go:",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What actually happens in Go:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "UR4O8B0M96rQJQZWnrFhT",
      "type": "text",
      "x": 6094.351384911166,
      "y": -429.17148854395055,
      "width": 718.8195190429688,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCh",
      "roundness": null,
      "seed": 88875558,
      "version": 86,
      "versionNonce": 1802354618,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "Accept() is called — the goroutine asks the Go runtime \"give me the next\nconnection from the accept queue\"",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Accept() is called — the goroutine asks the Go runtime \"give me the next connection from the accept queue\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "6EF2MCNLgZx1LvsEtEBnI",
      "type": "text",
      "x": 6094.351384911166,
      "y": -363.19555561639754,
      "width": 761.4194946289062,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCi",
      "roundness": null,
      "seed": 688975206,
      "version": 88,
      "versionNonce": 1037154426,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "If the accept queue is empty, the Go runtime parks the goroutine (removes it\nfrom the OS thread, marks it as waiting)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the accept queue is empty, the Go runtime parks the goroutine (removes it from the OS thread, marks it as waiting)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "e-DQ1jM3LGXTGG2mvFmfM",
      "type": "text",
      "x": 6094.351384911166,
      "y": -297.21962268884545,
      "width": 713.9395141601562,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCj",
      "roundness": null,
      "seed": 1754943654,
      "version": 90,
      "versionNonce": 985176378,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "The kernel handles the entire handshake independently — no goroutine is\ninvolved, no thread is consumed",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The kernel handles the entire handshake independently — no goroutine is involved, no thread is consumed",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "wks-12Xcp6pDrnFuJv6e_",
      "type": "text",
      "x": 6094.351384911166,
      "y": -231.24368976129335,
      "width": 768.719482421875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCk",
      "roundness": null,
      "seed": 261442534,
      "version": 146,
      "versionNonce": 1636131322,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "When the ACK arrives and the kernel moves cli:tcp_sock to ESTABLISHED and\nputs it in the accept queue, the kernel fires an epoll event on the listening\nsocket's fd",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the ACK arrives and the kernel moves cli:tcp_sock to ESTABLISHED and puts it in the accept queue, the kernel fires an epoll event on the listening socket's fd",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "yuB14ZuMPAar70-ZXF2yW",
      "type": "text",
      "x": 6094.351384911166,
      "y": -140.26775683374035,
      "width": 760.5393676757812,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCl",
      "roundness": null,
      "seed": 1812913958,
      "version": 125,
      "versionNonce": 1295717050,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "Go's netpoller (running on a separate OS thread) picks up this epoll event and\nunparks the goroutine",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Go's netpoller (running on a separate OS thread) picks up this epoll event and unparks the goroutine",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "bv2bH-eyGOLyc7jViKW1S",
      "type": "text",
      "x": 6094.351384911166,
      "y": -74.29182390618826,
      "width": 526.2596435546875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "cGnMescUCJwmCWpTc7rjF"
      ],
      "frameId": null,
      "index": "bCm",
      "roundness": null,
      "seed": 41159270,
      "version": 123,
      "versionNonce": 1081912186,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "The goroutine resumes, Accept() returns conn (fd=10)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The goroutine resumes, Accept() returns conn (fd=10)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SRP44RR7JcrQwgZ6hCL5l",
      "type": "rectangle",
      "x": 1042.5771886718667,
      "y": -846.4048002150903,
      "width": 278.0422736743133,
      "height": 75.83508281007045,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCn",
      "roundness": {
        "type": 3
      },
      "seed": 1100074406,
      "version": 153,
      "versionNonce": 831335482,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "bEYeBRFAb7WYnA6DdLh5g"
        }
      ],
      "updated": 1777704375435,
      "link": null,
      "locked": false
    },
    {
      "id": "bEYeBRFAb7WYnA6DdLh5g",
      "type": "text",
      "x": 1059.8184106530664,
      "y": -820.9872588100551,
      "width": 243.55982971191406,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCo",
      "roundness": null,
      "seed": 915744998,
      "version": 114,
      "versionNonce": 1448056058,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777704375435,
      "link": null,
      "locked": false,
      "text": "net.Listen(\"tcp\", \":8080\")",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "SRP44RR7JcrQwgZ6hCL5l",
      "originalText": "net.Listen(\"tcp\", \":8080\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
