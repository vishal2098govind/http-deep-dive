      "boundElements": [],
      "updated": 1777812450506,
      "link": null,
      "locked": false,
      "text": "kernel checks if reference count\nbecomes 0 (i.e. this connection is\nnot being reused by any other\nprocess/go-routine), frees fd=10\nfrom the process-fd-table\n\nthen sends FIN packet",
      "fontSize": 15.998848707443635,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "sDK9PxKS7mPtoPHcBqCUB",
      "originalText": "kernel checks if reference count becomes 0 (i.e. this connection is not being reused by any other process/go-routine), frees fd=10 from the process-fd-table\n\nthen sends FIN packet",
      "autoResize": true,
      "lineHeight": 1.25
    },
