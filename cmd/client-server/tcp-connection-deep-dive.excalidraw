      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkZ",
      "roundness": null,
      "seed": 1889461542,
      "version": 444,
      "versionNonce": 969375290,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "The goroutine is unparked\nonly when something arrives\nin the accept queue.",
      "fontSize": 60.53514223443345,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The goroutine is unparked only when something arrives in the accept queue.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "qoWM_WlSkoLym5fF2-ZBz",
      "type": "text",
      "x": 13739.866967265902,
      "y": 9616.805035002948,
      "width": 281.11981201171875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bka",
      "roundness": null,
      "seed": 1125339238,
      "version": 87,
      "versionNonce": 1198499578,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "What actually happens in Go:",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What actually happens in Go:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ajiu26wY7D5edf9y3nKAs",
      "type": "text",
      "x": 13739.738486243008,
      "y": 9674.305035002948,
      "width": 718.8195190429688,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bkb",
      "roundness": null,
      "seed": 2052608934,
      "version": 88,
      "versionNonce": 1737799610,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "Accept() is called — the goroutine asks the Go runtime \"give me the next\nconnection from the accept queue\"",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Accept() is called — the goroutine asks the Go runtime \"give me the next connection from the accept queue\"",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "4kX5vEQqA5dDxzmCCr7HN",
      "type": "text",
      "x": 13739.738486243008,
      "y": 9740.280967930503,
      "width": 761.4194946289062,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bkc",
      "roundness": null,
      "seed": 1620766438,
      "version": 90,
      "versionNonce": 173650042,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "If the accept queue is empty, the Go runtime parks the goroutine (removes it\nfrom the OS thread, marks it as waiting)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "If the accept queue is empty, the Go runtime parks the goroutine (removes it from the OS thread, marks it as waiting)",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "-bcrErLcE49XaNX0hdgtd",
      "type": "text",
      "x": 13739.738486243008,
      "y": 9806.256900858054,
      "width": 713.9395141601562,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bkd",
      "roundness": null,
      "seed": 1919427110,
      "version": 92,
      "versionNonce": 595693882,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "The kernel handles the entire handshake independently — no goroutine is\ninvolved, no thread is consumed",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The kernel handles the entire handshake independently — no goroutine is involved, no thread is consumed",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "7hqm3C_vUdYx2YXbaJZR2",
      "type": "text",
      "x": 13739.738486243008,
      "y": 9872.232833785605,
      "width": 768.719482421875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bke",
      "roundness": null,
      "seed": 313322854,
      "version": 148,
      "versionNonce": 913267194,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "When the ACK arrives and the kernel moves cli:tcp_sock to ESTABLISHED and\nputs it in the accept queue, the kernel fires an epoll event on the listening\nsocket's fd",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When the ACK arrives and the kernel moves cli:tcp_sock to ESTABLISHED and puts it in the accept queue, the kernel fires an epoll event on the listening socket's fd",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "jvzAew-XTZn-mkbGEtLaG",
      "type": "text",
      "x": 13739.738486243008,
      "y": 9963.208766713158,
      "width": 760.5393676757812,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bkf",
      "roundness": null,
      "seed": 1052135590,
      "version": 127,
      "versionNonce": 1646660282,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "Go's netpoller (running on a separate OS thread) picks up this epoll event and\nunparks the goroutine",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Go's netpoller (running on a separate OS thread) picks up this epoll event and unparks the goroutine",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "e5zF9kg5JRIgUBwzD0sT6",
      "type": "text",
      "x": 13739.738486243008,
      "y": 10029.184699640711,
      "width": 526.2596435546875,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "3tX8NnNr8Fkw1QH_Ofw6b"
      ],
      "frameId": null,
      "index": "bkg",
      "roundness": null,
      "seed": 1110526950,
      "version": 125,
      "versionNonce": 1833476986,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "The goroutine resumes, Accept() returns conn (fd=10)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The goroutine resumes, Accept() returns conn (fd=10)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "CRgFOqmJqinxjCyeb76QN",
      "type": "rectangle",
      "x": 8687.964290003707,
      "y": 9257.07172333181,
      "width": 278.0422736743133,
      "height": 75.83508281007045,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bkh",
      "roundness": {
        "type": 3
      },
      "seed": 1797971750,
      "version": 155,
      "versionNonce": 1377444922,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "ZbKiFzLJIr6O7E0NReQkC"
        }
      ],
      "updated": 1777812450485,
      "link": null,
      "locked": false
    },
    {
      "id": "ZbKiFzLJIr6O7E0NReQkC",
      "type": "text",
      "x": 8705.205511984906,
      "y": 9282.489264736845,
      "width": 243.55982971191406,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bki",
      "roundness": null,
      "seed": 1041238630,
      "version": 116,
      "versionNonce": 1249742074,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777812450485,
      "link": null,
      "locked": false,
      "text": "net.Listen(\"tcp\", \":8080\")",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "CRgFOqmJqinxjCyeb76QN",
      "originalText": "net.Listen(\"tcp\", \":8080\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
